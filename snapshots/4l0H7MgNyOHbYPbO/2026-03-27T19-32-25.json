          "jsCode": "// Pull from Extract Context directly — Slack continueOnFail can corrupt $input\nconst item = $('Extract Context').first().json;\nconst errMsg = item.error_message || 'Unknown error';\nconst severity = item.severity || 'UNKNOWN';\nconst wfName = item.workflow_name || 'unknown';\nconst errorCategory = item.error_category || 'unknown';\n\nlet retryStatus = 'none';\ntry { retryStatus = $input.first().json.retry_status || 'none'; } catch(e) {}\n\nreturn [{ json: {\n  timestamp: new Date().toISOString(),\n  category: 'error',\n  domain: wfName,\n  summary: '[' + severity + '][' + errorCategory + '] ' + wfName + ': ' + errMsg.substring(0, 100),\n  details: JSON.stringify({\n    eid: item.execution_id || 'unknown',\n    wid: item.workflow_id || 'unknown',\n    node: item.node_name || 'unknown',\n    err: errMsg,\n    sev: severity,\n    cat: errorCategory,\n    trans: item.is_transient || false,\n    retry: retryStatus\n  }),\n  session_id: 'global-error-handler'\n} }];"
