          "mode": "runOnceForAllItems",
          "jsCode": "const item = $input.first().json;\nconst execution = item.execution || {};\nconst workflow = item.workflow || {};\nconst error = execution.error || {};\nconst cause = error.cause || {};\n\nconst errorMessage = error.message || 'Unknown error';\nconst msg = errorMessage.toLowerCase();\nconst statusCode = cause.status || cause.statusCode || 0;\nconst lastNode = execution.lastNodeExecuted || 'unknown';\nconst executionId = execution.id || 'unknown';\nconst executionUrl = execution.url || '';\nconst executionMode = execution.mode || 'unknown';\nconst retryOf = execution.retryOf || null;\nconst workflowId = workflow.id || 'unknown';\nconst workflowName = workflow.name || 'unknown';\n\n// Transient: safe to auto-retry\nconst isTransient = (\n  msg.includes('429') || msg.includes('rate limit') || msg.includes('503') ||\n  msg.includes('timeout') || msg.includes('timed out') || msg.includes('econnaborted') ||\n  msg.includes('econnreset') || msg.includes('socket hang up') || msg.includes('502')\n);\n\n// Granular error category (from payload)\nlet error_category = 'unknown';\nif (statusCode === 401 || statusCode === 403 ||\n    msg.includes('unauthorized') || msg.includes('forbidden') ||\n    msg.includes('authentication') || msg.includes('invalid token') || msg.includes('credential')) {\n  error_category = 'auth_error';\n} else if (statusCode === 429 || msg.includes('rate limit') ||\n    msg.includes('too many requests') || msg.includes('quota exceeded')) {\n  error_category = 'rate_limit';\n} else if (msg.includes('timeout') || msg.includes('timed out') ||\n    msg.includes('econnaborted') || msg.includes('econnreset') || msg.includes('socket hang up')) {\n  error_category = 'timeout';\n} else if (statusCode >= 500) {\n  error_category = 'api_error_5xx';\n} else if (statusCode === 400 || statusCode === 422 ||\n    msg.includes('validation') || msg.includes('invalid')) {\n  error_category = 'validation_error';\n} else if (statusCode >= 400 && statusCode < 500) {\n  error_category = 'api_error_4xx';\n} else if (msg.includes('cannot read') || msg.includes('is not a function') ||\n    msg.includes('is not defined') || msg.includes('null')) {\n  error_category = 'code_error';\n} else if (errorMessage) {\n  error_category = 'runtime_error';\n}\n\n// Severity (from workflow name convention)\nconst nl = workflowName.toLowerCase();\nlet severity = 'MEDIUM';\nif (nl.includes('gateway') || nl.includes('handover') || nl.includes('backup') || nl.includes('orchestrate')) {\n  severity = 'CRITICAL';\n} else if (nl.includes('handler') || nl.includes('crm') || nl.includes('ads') ||\n    nl.includes('analytics') || nl.includes('google suite') || nl.includes('platform') ||\n    nl.includes('catalog') || nl.includes('doc sync')) {\n  severity = 'HIGH';\n} else if (nl.includes('test') || nl.includes('dev') || nl.includes('debug')) {\n  severity = 'LOW';\n}\n\n// Category overrides: auth errors always critical, code errors always high\nif (error_category === 'auth_error') severity = 'CRITICAL';\nif (error_category === 'code_error' && severity !== 'CRITICAL') severity = 'HIGH';\n\nreturn [{ json: {\n  execution_id: executionId,\n  execution_url: executionUrl,\n  execution_mode: executionMode,\n  retry_of: retryOf,\n  workflow_id: workflowId,\n  workflow_name: workflowName,\n  node_name: lastNode,\n  error_message: errorMessage,\n  error_category,\n  severity,\n  is_transient: isTransient,\n  timestamp: new Date().toISOString()\n} }];"
