          "jsCode": "const item = $input.first().json;\nconst eid = item.execution_id;\nconst mode = item.execution_mode;\nconst retryOf = item.retry_of;\n\n// Never retry if already a retry, or no execution ID\nif (!eid || eid === 'unknown' || mode === 'retry' || retryOf) {\n  const reason = (!eid || eid === 'unknown') ? 'no_execution_id'\n    : (mode === 'retry') ? 'already_a_retry'\n    : 'is_retry_of_' + retryOf;\n  return [{ json: { ...item, retry_status: 'skipped', skip_reason: reason } }];\n}\n\nreturn [{ json: {\n  ...item,\n  retry_status: 'queued',\n  retry_url: $vars.N8N_HOST + '/api/v1/executions/' + eid + '/retry'\n} }];"
