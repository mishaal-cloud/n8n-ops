      {
        "parameters": {
          "jsCode": "// Filter retryable executions with dedup via static data\n// Prevents retry storms: each execution retried at most once\nconst executions = $input.all().map(i => i.json);\nconst data = executions[0]?.data || executions;\nconst now = Date.now();\nconst TWENTY_FOUR_HOURS = 24 * 60 * 60 * 1000;\nconst FORTY_EIGHT_HOURS = 48 * 60 * 60 * 1000;\nconst MAX_BATCH = 5;\n\n// Self-exclusion: never retry our own workflow to prevent infinite loops\nconst SELF_WORKFLOW_ID = 'D5mAeRvuiw40iHTd';\n\n// Dedup: track retried execution IDs in workflow static data\nconst staticData = $getWorkflowStaticData('global');\nif (!staticData.retriedIds) staticData.retriedIds = {};\n\n// Clean entries older than 48h to prevent unbounded growth\nfor (const [id, ts] of Object.entries(staticData.retriedIds)) {\n  if (now - ts > FORTY_EIGHT_HOURS) delete staticData.retriedIds[id];\n}\n\nconst candidates = (Array.isArray(data) ? data : [])\n  .filter(e => {\n    if (!e.startedAt) return false;\n    if (staticData.retriedIds[e.id]) return false;\n    if (e.workflowId === SELF_WORKFLOW_ID) return false;\n    const age = now - new Date(e.startedAt).getTime();\n    return age < TWENTY_FOUR_HOURS;\n  })\n  .slice(0, MAX_BATCH);\n\nif (candidates.length === 0) {\n  return [{ json: { action: 'skip', reason: 'No retryable executions found', count: 0 } }];\n}\n\ncandidates.forEach(e => {\n  staticData.retriedIds[e.id] = now;\n});\n\nreturn candidates.map(e => ({\n  json: {\n    action: 'retry',\n    execution_id: e.id,\n    workflow_id: e.workflowId,\n    workflow_name: e.workflowData?.name || e.workflowId || 'unknown',\n    started_at: e.startedAt,\n    status: e.status\n  }\n}));"
        },
