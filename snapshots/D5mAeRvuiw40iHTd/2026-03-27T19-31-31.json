      {
        "parameters": {
          "jsCode": "const items = $input.all();\nconst results = items.map(item => {\n  const wasError = item.json?.error || item.json?.message?.includes('error');\n  return {\n    json: {\n      execution_id: item.json?.execution_id || item.json?.id || 'unknown',\n      retry_status: wasError ? 'failed' : 'retried',\n      timestamp: new Date().toISOString(),\n      details: item.json\n    }\n  };\n});\n\nconst succeeded = results.filter(r => r.json.retry_status === 'retried').length;\nconst failed = results.filter(r => r.json.retry_status === 'failed').length;\n\nreturn [{\n  json: {\n    summary: 'Auto-retry complete: ' + succeeded + ' retried, ' + failed + ' failed',\n    succeeded,\n    failed,\n    total: results.length,\n    results: results.map(r => r.json)\n  }\n}];"
        },
